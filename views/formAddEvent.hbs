<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Ajouter un Évènement</title>
</head>
<body>
    <div class="px-4 md:px-8 min-h-screen flex flex-col items-center justify-center bg-[url('/views/img/fond1.jpg')] bg-cover bg-center">
        <div class="max-w-md w-full">
            <div class="p-6 rounded-lg bg-slate-50 my-5 border border-slate-300 shadow-xs md:p-6 z-50">
                <h1 class="text-slate-900 text-center text-2xl font-bold">Ajouter un évènement</h1>

                <form class="space-y-2 flex flex-col" action="/events" method="POST" enctype="multipart/form-data">
                    <div>
                        <label for="title" class="text-slate-900 font-semibold text-[0.8rem] inline-block uppercase">title</label>
                        <input type="text" id="title" name="title" placeholder="title..." required
                            class="px-3 py-2.5 text-sm text-slate-900 rounded-md bg-white w-full outline-1 -outline-offset-1 outline-slate-300 focus:outline-2 focus:-outline-offset-2 focus:outline-blue-600" />
                    </div>
                    
                    <div>
                        <label for="lieu" class="text-slate-900 font-semibold text-[0.8rem] inline-block uppercase">lieu</label>
                        <input type="text" id="lieu" name="lieu" placeholder="LPS..." required
                            class="px-3 py-2.5 text-sm text-slate-900 rounded-md bg-white w-full outline-1 -outline-offset-1 outline-slate-300 focus:outline-2 focus:-outline-offset-2 focus:outline-blue-600" />
                    </div>
                    
                    <div>
                        <label for="artist" class="text-slate-900 font-semibold text-[0.8rem] inline-block uppercase">artist</label>
                        <input type="text" id="artist" name="artist" placeholder="artist or group" required
                            class="px-3 py-2.5 text-sm text-slate-900 rounded-md bg-white w-full outline-1 -outline-offset-1 outline-slate-300 focus:outline-2 focus:-outline-offset-2 focus:outline-blue-600" />
                    </div>
                    
                    <div>
                        <label for="description" class="text-slate-900 font-semibold text-[0.8rem] uppercase inline-block">descript</label>
                        <input type="text" id="descript" name="descript" placeholder="description" required
                            class="px-3 py-2.5 text-sm text-slate-900 rounded-md bg-white w-full outline-1 -outline-offset-1 outline-slate-300 focus:outline-2 focus:-outline-offset-2 focus:outline-blue-600" />
                    </div>
                    
                    <div>
                        <label class="font-semibold uppercase text-[0.8rem]" for="start">Date de l'evenement&nbsp;:</label>
                        <input type="date" id="start" name="date_event" min="2026-01-01" max="2036-12-31" required/>
                    </div>

                    <div class="flex items-center gap-1">
                        <label class="block mb-1 text-[0.8rem] text-slate-800 font-semibold uppercase">Type</label>
                        <div class="relative w-full">
                            <select name="type" class="w-full bg-transparent text-slate-700 text-sm border border-slate-200 rounded pl-3 pr-8 py-2 transition duration-300 ease focus:outline-none focus:border-slate-400 hover:border-slate-400 shadow-sm focus:shadow-md appearance-none cursor-pointer">
                                <option value="concert">Concert</option>
                                <option value="event">Event</option>
                            </select>
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="h-5 w-5 ml-1 absolute top-2.5 right-2.5 text-slate-700">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 15 12 18.75 15.75 15m-7.5-6L12 5.25 15.75 9" />
                            </svg>
                        </div>
                    </div>

                    <div class="uppercase">
                        <label class="font-semibold text-[0.8rem]" for="ticketNum">Price&nbsp;</label>
                        <input class="bg-transparent text-slate-700 text-sm border border-slate-200 rounded pl-3 pr-8 py-2 transition duration-300 ease focus:outline-none focus:border-slate-400 hover:border-slate-400 shadow-sm focus:shadow-md appearance-none cursor-pointer" id="ticketNum" type="number" name="price" value="0" min="0"/>
                        <span>Fcfa</span>
                    </div>

                    <div class="flex justify-center">
                        <label id="dropZone" for="fileInput" class="border bg-white rounded-md text-[10px] w-70 h-30 border-indigo-600/60 p-5 flex flex-col items-center justify-center gap-2 cursor-pointer hover:border-indigo-500 transition-all duration-200">
                            <svg width="44" height="20" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M25.665 3.667H11a3.667 3.667 0 0 0-3.667 3.666v29.334A3.667 3.667 0 0 0 11 40.333h22a3.667 3.667 0 0 0 3.666-3.666v-22m-11-11 11 11m-11-11v11h11m-7.333 9.166H14.665m14.667 7.334H14.665M18.332 16.5h-3.667" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <div id="dropZoneText" class="text-center">
                                <p class="text-gray-500 font-medium">Glisse & dépose ton image ici</p>
                                <p class="text-gray-400">Ou <span class="text-indigo-500 underline">clique</span> pour parcourir</p>
                            </div>
                            <input id="fileInput" type="file" name="image" class="hidden" accept="image/*" />
                        </label>
                    </div>

                    <button type="submit" class="w-full py-2 px-3.5 text-sm rounded-md font-semibold cursor-pointer tracking-wide text-white border border-blue-600 bg-blue-600 hover:bg-blue-700 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500">
                        Create event
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const dropZoneText = document.getElementById('dropZoneText');

        // Empêcher le comportement par défaut du navigateur (ouvrir l'image dans un nouvel onglet)
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, e => e.preventDefault(), false);
        });

        // Effets visuels quand on survole la zone avec un fichier
        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => {
                dropZone.classList.add('border-indigo-500', 'bg-indigo-50/50', 'scale-105');
            }, false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => {
                dropZone.classList.remove('border-indigo-500', 'bg-indigo-50/50', 'scale-105');
            }, false);
        });

        // Gestion du dépôt du fichier
        dropZone.addEventListener('drop', e => {
            const dt = e.dataTransfer;
            const files = dt.files;

            if (files.length > 0) {
                fileInput.files = files; // On injecte le fichier déposé dans le input hidden
                updatePreviewName(files[0].name);
            }
        });

        // Gestion du clic classique (changement via explorateur de fichiers)
        fileInput.addEventListener('change', () => {
            if (fileInput.files.length > 0) {
                updatePreviewName(fileInput.files[0].name);
            }
        });

        // Mettre à jour le texte de la zone pour valider la sélection
        function updatePreviewName(name) {
            dropZoneText.innerHTML = `
                <p class="text-green-600 font-bold text-xs"> Image sélectionnée :</p>
                <p class="text-gray-700 font-medium truncate max-w-[200px]">${name}</p>
            `;
            dropZone.classList.add('border-green-500');
        }
    </script>
</body>
</html>