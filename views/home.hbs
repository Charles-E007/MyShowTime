<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <title>Document</title>
</head>
<body>
    <style>
    @import url('https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap');

    * {
        font-family: 'Poppins', sans-serif;
    }

    .marquee-inner {
        animation: marqueeScroll 35s linear infinite;
    }

    @keyframes marqueeScroll {
        0% {
            transform: translateX(0%);
        }

        100% {
            transform: translateX(-50%);
        }
    }
</style>



<header class="fixed top-0 left-0 w-full bg-white shadow-md z-50">

    <nav class="flex items-center justify-between p-4 border-b border-slate-200 md:px-16 lg:px-24 xl:px-32 w-full  ">
        <a href="/">   
            <h1 class="font-bold text-xl">MyShowTime</h1>
            
        </a>
        <div id="menu" class="max-md:absolute max-md:top-0 max-md:z-10 max-md:left-0 max-md:w-0 max-md:transition-all max-md:duration-300 max-md:overflow-hidden max-md:h-full max-md:bg-white/50 max-md:backdrop-blur max-md:flex-col max-md:justify-center flex items-center gap-8 font-medium">
            <a href="/" class="hover:text-gray-500">
                Home
            </a>
            <a href="#concert" class="relative group flex items-center gap-1 cursor-pointer">
                <span>Evenement</span>
            </a>
            <a href="#about" class="hover:text-gray-500">About</a>
         
            <button id="close-menu" class="md:hidden bg-gray-900 hover:bg-gray-800 text-white p-2 rounded-md aspect-square font-medium transition">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 6 6 18" />
                    <path d="m6 6 12 12" />
                </svg>
            </button>
        </div>
        <div class="flex items-center gap-4">
            {{#if user}}
                {{#if (eq user.role "admin")}}
                    <a href="/admin/dashboard-users" class="hidden md:block bg-black hover:bg-black text-white px-4 py-2 rounded-full font-medium transition">
                        Admin
                    </a>
                {{/if}}
                <span class="font-medium text-slate-900 uppercase">{{user.name}}</span>
                <a href="/auth/logout" class="hidden md:block bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-full font-medium transition">
                    Déconnexion
                </a>
                <a href="/users/{{user._id}}" class="hidden md:block bg-green-500 hover:bg-yellow-300 text-white px-4 py-2 rounded-full font-medium transition">
                    Profile
                </a>
            {{else}}
                <a href="/login" class="hidden mr-2 md:block bg-green-600 hover:bg-slate-900 text-white px-4 py-2 rounded-full font-medium transition">
                    Sign in
                </a>
                <a href="/register" class="hidden md:block bg-slate-800 hover:bg-slate-900 text-white px-4 py-2 rounded-full font-medium transition">
                    Sign up
                </a>
            {{/if}}
        </div>
        <button id="open-menu"
            class="md:hidden bg-gray-900 hover:bg-gray-800 text-white p-2 rounded-md aspect-square font-medium transition">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 12h16" />
                <path d="M4 18h16" />
                <path d="M4 6h16" />
            </svg>
        </button>
    </nav>
</header>


<section id="hero" class="flex flex-col items-center bg-[url('https://raw.githubusercontent.com/prebuiltui/prebuiltui/main/assets/hero/gradientBg.svg')] bg-cover text-gray-800 pb-16 h-90 mt-18">
    


    <h1
        class="text-4xl md:text-6xl text-center font-medium max-w-3xl mt-5 bg-gradient-to-r from-black to-[#748298] text-transparent bg-clip-text">
        Trouver vos Evenement et Concert
    </h1>
    <p class="text-slate-600 md:text-base max-md:px-2 text-center max-w-xl mt-3">
        Tous vos brunch, festival, ceremonie et concert tendance en un click
    </p>

    <a href="#concert" class="flex items-center gap-2 bg-slate-800 hover:bg-slate-900 text-white px-8 py-3 mt-8 rounded-full transition">
        <span>Prend ton ticket</span>
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4.166 10h11.667m0 0L9.999 4.167M15.833 10l-5.834 5.834" stroke="#fff" stroke-width="1.8"
                stroke-linecap="round" stroke-linejoin="round" />
        </svg>
    </a>

    <div class="overflow-hidden w-full relative max-w-5xl mx-auto select-none mt-16">
        <div
            class="absolute left-0 top-0 h-full w-20 z-10 pointer-events-none bg-gradient-to-r from-[#f5f7ff] to-transparent">
        </div>

        <div class="marquee-inner flex will-change-transform min-w-[200%]">
            <div class="flex py-4" id="logo-container">
            </div>
        </div>

        <div
            class="absolute right-0 top-0 h-full w-20 md:w-40 z-10 pointer-events-none bg-gradient-to-l from-[#efe9f4] to-transparent">
        </div>
    </div>
</section>




<main  id="concert" class="mt-5 border-b border-slate-200 pb-20">
    <div class="flex items-center justify-center p-4 border-b border-slate-200 md:px-16 lg:px-24 xl:px-32 w-full">
        <h2 class="font-bold text-xl uppercase tracking-tight">tous nos Evenements</h2>
    </div>


    <div class="flex flex-wrap justify-center ">

        {{#each events}}
            <div class="min-w-2xs max-w-xs rounded-2xl overflow-hidden shadow-lg bg-white border border-gray-100 m-3">
                <a href="/events/{{this._id}}" class="relative h-64 bg-gray-200 block overflow-hidden">
                {{#if this.imageUrl}}
                    <img src="/uploads/{{this.imageUrl}}" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" alt="{{this.title}}">
                {{else}}
                    <img src="/uploads/events/Vice_City_04.jpg" class="w-full h-full object-cover" alt="Default Cover">
                {{/if}}
                <span class="absolute bottom-3 right-3 bg-red-500 text-white text-xs px-3 py-1 rounded-md">
                    <p>{{this.type}}</p>
                </span>
                </a>
            
                <div class="p-3">
                    <div class="flex justify-between items-start">
                        <h2 class="font-bold text-xl uppercase tracking-tight">{{this.title}}</h2>
                        <div class="flex flex-col items-center text-gray-500">
                            <!-- Icône cœur -->
                                    <svg xmlns="http://www.w3.org/2000/svg"  width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-heart-icon lucide-heart like"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"/></svg>

                        </div>
                    </div>
            
                    <div class="flex flex-col">
                        <div class="mt-1 text-sm text-gray-600">
                            <div class="flex items-center justify-center">
                                <span class="font-medium">{{this.date_event}}</span>
                            </div>
                            <div class="flex items-center justify-center text-green-600">
                                <span class="font-bold">À partir de {{this.price}} F CFA</span>
                            </div>
                            <div class="flex items-center justify-center">
                                <span>{{this.lieu}}</span>
                            </div>
                        </div>
            
                        <a href="/events/{{this._id}}"
                            class="w-min self-center bg-red-400 text-white font-bold rounded-full mt-2 hover:bg-red-500 transition">
                            <p class="px-2 py-1">Réservation</p>
                        </a>
                    </div>
                </div>
            </div>
            {{/each}}












    </div>
</main>


<footer class="px-6 md:px-16 lg:px-24 xl:px-32 pt-8 w-full text-gray-500" id="about">
    <div class="flex flex-col md:flex-row justify-between w-full gap-10 border-b border-gray-500/30 pb-6">
        <div class="md:max-w-96">
          <h1 class="font-bold text-xl" >MyShowTime</h1>
            <p class="mt-6 text-sm">
                simplifie l'organisation d'événements grâce à
                une solution complète et intuitive. 
                Notre plateforme permet aux public de 
                reserver facilement les evenements.
            </p>
        </div>
        <div class="flex-1 flex items-start md:justify-end gap-20">
            <div>
                <h2 class="font-semibold mb-5 text-gray-800">MyShowTime</h2>
                <ul class="text-sm space-y-2">
                    <li><a href="#">Home</a></li>
                    <!-- <li><a href="#">About us</a></li> -->Sat 6 Jun 2026 | 16h00 GMT

                    <li><a href="#">Contact us</a></li>
                    <li><a href="#">Privacy policy</a></li>
                </ul>
            </div>
            <div>
                <h2 class="font-semibold mb-5 text-gray-800">Get in touch</h2>
                <div class="text-sm space-y-2">
                    <p>+225-07-05-44-25-96</p>
                    <p>myshowtime@gmail.com</p>
                </div>
            </div>
        </div>
    </div>
    <p class="pt-4 text-center text-xs md:text-sm pb-5">
        Copyright wecode 2026 © <a href="#">Code Breakers</a>. All Right Reserved.
    </p>
</footer>

</body>

<script>
    const menu = document.getElementById('menu');
    const closeMenu = document.getElementById('close-menu');
    const openMenu = document.getElementById('open-menu');

    closeMenu.addEventListener('click', () => {
        menu.classList.remove('max-md:w-50');
        menu.classList.add('max-md:w-0');
    });

    openMenu.addEventListener('click', () => {
        menu.classList.remove('max-md:w-0');
        menu.classList.add('max-md:w-50');
    });


    const blike = document.querySelectorAll(".like")
    console.log(blike);

    for (let index = 0; index < blike.length; index++) {
        const element = blike[index];
        console.log(element);
     
        
         element.addEventListener('click', ()=> {

        if (element.getAttribute("fill")=== "gray"){
            element.setAttribute("fill", "none");
            element.setAttribute("stroke", "currentColor");

        }else{
            element.setAttribute("fill", "gray");
            element.setAttribute("stroke", "none");

        }
    })
    }

   

   
</script>
</html>